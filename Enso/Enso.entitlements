<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Hardened runtime denies microphone access outright without this;
	     needed so CLI tools running in Enso (e.g. voice dictation) can
	     trigger the mic permission prompt, attributed to Enso. -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
</dict>
</plist>
